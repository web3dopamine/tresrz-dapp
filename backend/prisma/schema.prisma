generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  address   String   @unique            // checksummed wallet address
  handle    String?  @unique
  avatarSeed Int     @default(0)
  bio       String?
  flagged   Boolean  @default(false)    // admin moderation flag
  createdAt DateTime @default(now())
  tracks    Track[]  @relation("ArtistTracks")
  likes     Like[]
  sales     Sale[]   @relation("BuyerSales")
  soldSales Sale[]   @relation("SellerSales")
}

model Track {
  id           String   @id @default(cuid())
  chainTokenId Int?     @unique          // tokenId on TresrzMusic contract
  title        String
  genre        String
  coverSeed    Int      @default(0)      // drives generative cover art
  audioUrl     String?                   // public preview URL (gateway/local)
  audioCid     String?                   // full-track IPFS CID (gated to holders)
  coverUrl     String?                   // cover image URL (IPFS/local), optional
  metadataUri  String?                   // ipfs:// or URL of ERC-721 metadata JSON
  mime         String?                   // audio mime type (e.g. audio/mpeg)
  priceWei     String   @default("0")    // primary price per edition (wei, string for bigint)
  maxSupply    Int
  minted       Int      @default(0)
  txHash       String?
  artist       User     @relation("ArtistTracks", fields: [artistId], references: [id])
  artistId     String
  hot          Boolean  @default(false)  // "featured" flag (admin-controlled)
  flagged      Boolean  @default(false)  // admin moderation flag (hidden from listings)
  createdAt    DateTime @default(now())
  likes        Like[]
  sales        Sale[]
}

// SIWE login nonces. DB-backed so issued nonces survive an API restart (the old
// in-memory Map dropped every pending login whenever the process bounced).
model SiweNonce {
  address   String   @id          // lower-cased wallet address
  nonce     String
  createdAt DateTime @default(now())
}

model Like {
  id      String @id @default(cuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String
  track   Track  @relation(fields: [trackId], references: [id])
  trackId String
  @@unique([userId, trackId])
}

model Sale {
  id       String   @id @default(cuid())
  track    Track    @relation(fields: [trackId], references: [id])
  trackId  String
  buyer    User     @relation("BuyerSales", fields: [buyerId], references: [id])
  buyerId  String
  seller   User?    @relation("SellerSales", fields: [sellerId], references: [id])
  sellerId String?                                  // null for primary sales
  kind     String   @default("primary")             // primary | secondary_listing | secondary_offer
  qty      Int
  priceWei String                                    // total paid (wei)
  txHash   String   @unique
  createdAt DateTime @default(now())
}
