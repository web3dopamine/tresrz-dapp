DATABASE_URL="postgresql://tresrz:tresrz@localhost:5432/tresrz?schema=public"
PORT=31338
JWT_SECRET="change_me_to_a_long_random_string"
# Comma-separated list of allowed browser origins (the frontend). Add your public origin too.
CORS_ORIGIN="http://localhost:31337"
# Host the browser uses. Used as the default SIWE domain; the backend also accepts the
# request Origin's host when that origin is listed in CORS_ORIGIN.
SIWE_DOMAIN="localhost:31337"
# Local chain + deployed TresrzMusic address. When set, the seed mints demo tracks
# on-chain so they are real and buyable; leave unset to seed off-chain (chainTokenId null).
RPC_URL="http://127.0.0.1:8545"
CHAIN_ID=31337
MUSIC_CONTRACT=""
# Secondary marketplace (TresrzMarketplace) address — required to verify resales.
MARKET_CONTRACT=""

# --- M3: IPFS pinning (Pinata). Leave PINATA_JWT empty to use the local-disk
#     fallback (files written to ./uploads and served at /uploads/*). ---
PINATA_JWT=""
PINATA_GATEWAY="https://gateway.pinata.cloud"
# Public base URL of THIS API, used to build absolute URLs for local fallback uploads.
PUBLIC_BASE_URL="http://localhost:31338"

# --- M4: Admin allowlist (comma-separated wallet addresses, usually the contract
#     owner / platform multisig). Gates /api/admin/* and the dashboard. ---
ADMIN_ADDRESSES=""

# --- USD pricing + Stripe card checkout (optional) ---
# Public URL of the frontend (Stripe success/cancel redirects)
PUBLIC_SITE_URL="https://your-domain.example"
# Wallet that fulfils card orders: buys editions on-chain and forwards them to
# the customer. Must hold ETH for purchases + gas. NEVER reuse a mainnet key.
DELIVERY_PRIVATE_KEY=
# From the Stripe dashboard (Developers -> API keys, and Webhooks -> signing secret
# for the endpoint https://<your-domain>/api/fiat/webhook). Card payments stay
# disabled until both are set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google (Gmail) sign-in ---
# OAuth 2.0 Web Client ID from Google Cloud Console (Google Auth Platform ->
# Clients). Authorized JavaScript origin must include your site URL. The button
# stays hidden until this is set. No client secret is needed (GIS ID-token flow).
GOOGLE_CLIENT_ID=
